# 클라이언트에 노출되는 값만 VITE_ 접두사 사용
# 복사: cp .env.example .env

# 비우거나 생략하면 api.js 기본값 `/api` (Vite proxy → localhost:8080)
VITE_API_BASE_URL=/api

# 원격/다른 포트 예시
# VITE_API_BASE_URL=http://localhost:8080/api

# Google Identity Services (프론트 공식 로그인 버튼)
# Google Cloud Console에서 Web client ID를 발급받아 입력
VITE_GOOGLE_CLIENT_ID=836691683549-5pdimuii5u9k1297mcqd67ningfgj63e.apps.googleusercontent.com

# 필요 시 테스트용 ID 토큰을 직접 넣어 확인
# 실제 운영에서는 백엔드 검증된 토큰만 사용
VITE_GOOGLE_ID_TOKEN=
